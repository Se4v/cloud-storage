<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.backend.mapper.StorageMapper">
    <update id="batchUpdateRefCount">
        UPDATE file_storage
        SET ref_count = CASE id
        <foreach collection="countMap.entrySet()" item="count" index="storageId" separator=" ">
            WHEN #{storageId} THEN ref_count - #{count}
        </foreach>
        END
        WHERE id IN
        <foreach collection="countMap.keySet()" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>
</mapper>